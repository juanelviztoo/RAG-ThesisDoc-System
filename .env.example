# ====== LLM Provider ======
# Pilih: groq | openai | ollama
LLM_PROVIDER=groq

# Groq (opsional)
GROQ_API_KEY=PASTE_YOUR_KEY_HERE
GROQ_MODEL=llama3-8b-8192

# OpenAI (opsional)
OPENAI_API_KEY=PASTE_YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# Ollama (opsional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ====== Cache locations (arahkan ke drive E:) ======
# HuggingFace / Transformers / SentenceTransformers cache
HF_HOME=E:/hf-cache
HUGGINGFACE_HUB_CACHE=E:/hf-cache/hub
SENTENCE_TRANSFORMERS_HOME=E:/hf-cache/sentence-transformers

# Pip cache (opsional)
PIP_CACHE_DIR=E:/pip-cache

# ====== Logging behavior (opsional) ======
# 1 = simpan config_snapshot di setiap baris JSONL (lebih aman tapi file lebih besar)
LOG_INCLUDE_CONFIG_PER_ROW=0